# --- System Configuration ---
DEFAULT_PROVIDER=openai
GITHUB_TOKEN=optional_github_token
AUDITOR_API_URL=http://localhost:4040
PORT=4040

# --- Gemini Note ---
# GEMINI_API_KEY can be a standard API key OR a Bearer token (ya29...) for OAuth.
